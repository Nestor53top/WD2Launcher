    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>WD2Launcher</RootNamespace>
    <AssemblyName>WD2Launcher</AssemblyName>
    <Version>1.0.0</Version>
    <Authors>WD2Launcher</Authors>
    <Description>Watch Dogs 2 Launcher with EAC bypass and trainer injection</Description>
